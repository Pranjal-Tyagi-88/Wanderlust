<% layout("/layouts/boilerplate") %>

    <div class="row mt-3">
        <div class="col-8 offset-2">

            <h3>
                <%= data.title %>
            </h3><br>

            <div class="card listing-card">
                <img src="<%= typeof data.image === 'string' ? data.image : data.image.url %>"
                    class="card-img-top show-img" alt="Location Image">

                <div class="card-body">
                    <p class="card-text">
                        <br>
                        <i><b> Owned by <%= data.owner.username %></i></b><br><br>
                    </p>
                    <p class="card-text">
                        <%= data.description %>
                    </p> <br>
                    <p class="card-text"> ₹ <%= data.price.toLocaleString("en-IN") %>
                    </p> <br>
                    <p class="card-text">
                        <%= data.location %>
                    </p> <br>
                    <p class="card-text">
                        <%= data.country %>
                    </p>
                </div>
            </div>

            <!-- 🔥 BUTTON ROW -->
            <% if(currUser && currUser._id.equals(data.owner._id)) { %>
                <div class="d-flex gap-3 mt-3">

                    <a href="/listing/<%= data._id %>/edit" class="btn btn-dark">
                        Edit
                    </a>


                    <form method="POST" action="/listing/<%= data._id %>?_method=DELETE">

                        <button class="btn btn-danger">
                            Delete
                        </button>

                    </form>

                </div>
                <% } %>
                    <br><br>

                    <% if(currUser){ %>
                        <div class="col-8 offset-2 mb-3">
                            <hr />
                            <h4>Leave a review </h4>
                            <form action="/listing/<%= data._id %>/reviews" method="POST" novalidate
                                class="needs-validation">

                                <div class="mb-3 mt-3">
                                    <label for="rating" class="form-label">Rating</label>
                                    <fieldset class="starability-slot">
                                        <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]"
                                            value="1" checked aria-label="No rating." />
                                        <input type="radio" id="first-rate1" name="review[rating]" value="1" />
                                        <label for="first-rate1" title="Terrible">1 star</label>
                                        <input type="radio" id="first-rate2" name="review[rating]" value="2" />
                                        <label for="first-rate2" title="Not good">2 stars</label>
                                        <input type="radio" id="first-rate3" name="review[rating]" value="3" />
                                        <label for="first-rate3" title="Average">3 stars</label>
                                        <input type="radio" id="first-rate4" name="review[rating]" value="4" />
                                        <label for="first-rate4" title="Very good">4 stars</label>
                                        <input type="radio" id="first-rate5" name="review[rating]" value="5" />
                                        <label for="first-rate5" title="Amazing">5 stars</label>
                                    </fieldset>
                                </div>

                                <div class="mb-3 mt-3">
                                    <label for="comment" class="form-label">Comments</label>
                                    <textarea required class="form-control" name="review[comment]" id="comment"
                                        cols="30" rows="10"></textarea>
                                    <div class="invalid-feedback">Comments are necessary to post a review. </div>
                                </div>
                                <button class="btn btn-outline-dark">Submit</button>
                            </form>

                            <%}%>

                                <hr />

                                <p>All reviews</p>
                                <div class="row">
                                    <% for(let review of data.reviews){ %>

                                        <div class="card col-5  ms-3 mb-3">
                                            <div class="card-body">
                                                <h5 class="card-title"> @ <%= review.author.username %>
                                                </h5>
                                                <p class="card-text">
                                                    <%= review.comment %>
                                                </p>
                                                <p class="card-text starability-result"
                                                    data-rating="<%= review.rating %>"></p>
                                                <form class="mb-3" method="POST"
                                                    action="/listing/<%= data._id %>/reviews/<%= review._id %>?_method=DELETE">
                                                    <button class="btn btn-sm btn-dark">Delete</button>
                                                </form>
                                            </div>
                                        </div>

                                        <% } %>
                                </div>

                        </div>
        </div>
    </div>