<% layout("/layouts/boilerplate") %>

<style>
    .show-img {
    max-height: 400px;
    object-fit: cover;
}
</style>

<div class="container mt-3">
    <div class="row">
        <div class="col-12 col-md-10 col-lg-8 mx-auto">

            <h3><%= data.title %></h3><br>

            <div class="card listing-card">
                <img src="<%= typeof data.image === 'string' ? data.image : data.image.url %>"
                     class="card-img-top show-img img-fluid" alt="Location Image">

                <div class="card-body">
                    <p class="card-text">
                        <i><b>Owned by <%= data.owner.username %></b></i>
                    </p>

                    <p class="card-text"><%= data.description %></p>

                    <p class="card-text">₹ <%= data.price.toLocaleString("en-IN") %></p>

                    <p class="card-text"><%= data.location %></p>

                    <p class="card-text"><%= data.country %></p>
                </div>
            </div>

            <!-- BUTTONS -->
            <% if(currUser && currUser._id.equals(data.owner._id)) { %>
                <div class="d-flex flex-column flex-sm-row gap-2 mt-3">

                    <a href="/listing/<%= data._id %>/edit" class="btn btn-dark">
                        Edit
                    </a>

                    <form method="POST" action="/listing/<%= data._id %>?_method=DELETE">
                        <button class="btn btn-danger w-100 w-sm-auto">
                            Delete
                        </button>
                    </form>

                </div>
            <% } %>

            <br><br>

            <!-- REVIEW FORM -->
            <% if(currUser){ %>
                <div class="mt-3">
                    <hr />
                    <h4>Leave a review</h4>

                    <form action="/listing/<%= data._id %>/reviews" method="POST" novalidate class="needs-validation">

                        <div class="mb-3 mt-3">
                            <label for="rating" class="form-label">Rating</label>

                            <fieldset class="starability-slot">
                                <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1" checked />
                                <input type="radio" id="first-rate1" name="review[rating]" value="1" />
                                <label for="first-rate1">1 star</label>

                                <input type="radio" id="first-rate2" name="review[rating]" value="2" />
                                <label for="first-rate2">2 stars</label>

                                <input type="radio" id="first-rate3" name="review[rating]" value="3" />
                                <label for="first-rate3">3 stars</label>

                                <input type="radio" id="first-rate4" name="review[rating]" value="4" />
                                <label for="first-rate4">4 stars</label>

                                <input type="radio" id="first-rate5" name="review[rating]" value="5" />
                                <label for="first-rate5">5 stars</label>
                            </fieldset>
                        </div>

                        <div class="mb-3 mt-3">
                            <label for="comment" class="form-label">Comments</label>
                            <textarea required class="form-control" name="review[comment]" id="comment" rows="5"></textarea>
                            <div class="invalid-feedback">
                                Comments are necessary to post a review.
                            </div>
                        </div>

                        <button class="btn btn-outline-dark">Submit</button>
                    </form>
                </div>
            <% } %>

            <hr />

            <!-- REVIEWS -->
            <p>All reviews</p>

            <div class="row">
                <% for(let review of data.reviews){ %>

                    <div class="col-12 col-md-6 mb-3">
                        <div class="card h-100">
                            <div class="card-body">

                                <h5 class="card-title">@ <%= review.author.username %></h5>

                                <p class="card-text"><%= review.comment %></p>

                                <p class="card-text starability-result"
                                   data-rating="<%= review.rating %>"></p>

                                <form method="POST"
                                      action="/listing/<%= data._id %>/reviews/<%= review._id %>?_method=DELETE">
                                    <button class="btn btn-sm btn-dark">
                                        Delete
                                    </button>
                                </form>

                            </div>
                        </div>
                    </div>

                <% } %>
            </div>

        </div>
    </div>
</div>