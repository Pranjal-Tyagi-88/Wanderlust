<% layout("/layouts/boilerplate") %>

    <body>
        <div class="row mt-3">
            <div class="col-8 offset-2">
                <h2>Edit your listing</h2>
                <br>

                <form action="/listing/<%= data.id %>?_method=PUT" method="post" novalidate class="needs-validation"
                    enctype="multipart/form-data">

                    <div class="mb-3">
                        <label class="form-label">Title</label>
                        <input type="text" name="listing[title]" value="<%= data.title %>" class="form-control"
                            required>
                        <div class="valid-feedback">Looks good!</div>
                        <div class="invalid-feedback">Please choose a title.</div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Description</label>
                        <textarea name="listing[description]" class="form-control"><%= data.description %></textarea>
                        <div class="valid-feedback">Looks good!</div>
                    </div>

                    <div class="mb-3">
                        Original Listing Image <br>
                        <img src="<%= originalUrl %>">
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Upload New Image</label>
                        <input name="listing[image]" type="file" class="form-control">
                        <div class="valid-feedback">Looks good!</div>
                    </div>

                    <div class="row">
                        <div class="mb-3 col-4">
                            <label class="form-label">Price</label>
                            <input type="number" name="listing[price]" value="<%= data.price %>" class="form-control"
                                required>
                            <div class="valid-feedback">Looks good!</div>
                            <div class="invalid-feedback">Please choose a valid price.</div>
                        </div>

                        <div class="mb-3 col-8">
                            <label class="form-label">Country</label>
                            <input type="text" name="listing[country]" value="<%= data.country %>" class="form-control"
                                required>
                            <div class="valid-feedback">Looks good!</div>
                            <div class="invalid-feedback">Please enter a valid country.</div>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Location</label>
                        <input type="text" name="listing[location]" value="<%= data.location %>" class="form-control"
                            required>
                        <div class="valid-feedback">Looks good!</div>
                        <div class="invalid-feedback">Please enter a valid location.</div>
                    </div>

                    <button class="btn btn-dark edit-btn mt-3">Submit</button>
                    <br><br>
                </form>
            </div>
        </div>
    </body>